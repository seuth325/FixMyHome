// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  role            Role      @default(HOMEOWNER)
  location        String?
  phone           String?
  photoUrl        String?
  isAvailable     Boolean   @default(true)
  emailOptOut     Boolean   @default(false)
  emailVerifiedAt DateTime?
  campaignSource  String?
  referralCode    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  handymanProfile         HandymanProfile?
  jobsPosted              Job[]                    @relation("JobsPosted")
  bidsSubmitted           Bid[]
  messagesSent            Message[]
  reviewsGiven            Review[]                 @relation("ReviewsGiven")
  reviewsReceived         Review[]                 @relation("ReviewsReceived")
  notifications           Notification[]
  jobInvitations          JobInvitation[]          @relation("HandymanInvitations")
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  reportsFiled            Report[]
}

enum Role {
  HOMEOWNER
  HANDYMAN
  ADMIN
}

model HandymanProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String?
  website            String?
  licenseNumber      String?
  isInsured          Boolean  @default(false)
  verificationStatus String   @default("UNVERIFIED")
  skills             Json     @default("[]")
  bio                String?  @db.Text
  serviceRadius      Int // miles
  hourlyRate         Decimal?
  ratingAvg          Decimal  @default(0)
  ratingCount        Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model HandymanLead {
  id           String   @id @default(cuid())
  sourceKey    String   @unique
  businessName String
  address      String?
  location     String?
  phone        String?
  email        String?
  website      String?
  services     String?  @db.Text
  sourceRating Decimal?
  outreachSent Boolean  @default(false)
  status       String   @default("PROSPECT")
  source       String
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([location])
  @@index([businessName])
}

model Job {
  id             String    @id @default(cuid())
  homeownerId    String
  homeowner      User      @relation("JobsPosted", fields: [homeownerId], references: [id], onDelete: Cascade)
  title          String
  description    String    @db.Text
  category       String
  location       String
  budget         Decimal
  preferredDate  DateTime?
  campaignSource String?
  referralCode   String?
  status         JobStatus @default(OPEN)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  awardedAt      DateTime?
  completedAt    DateTime?

  photos      JobPhoto[]
  bids        Bid[]
  messages    Message[]
  reviews     Review[]
  invitations JobInvitation[]

  @@index([homeownerId])
  @@index([status])
  @@index([category])
  @@index([location])
  @@index([status, createdAt])
}

enum JobStatus {
  OPEN
  IN_REVIEW
  AWARDED
  COMPLETED
  CANCELLED
}

model JobPhoto {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
}

model Bid {
  id         String    @id @default(cuid())
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  handymanId String
  handyman   User      @relation(fields: [handymanId], references: [id], onDelete: Cascade)
  amount     Decimal
  message    String    @db.Text
  etaDays    Int
  status     BidStatus @default(PENDING)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  messages      Message[]
  isRecommended Boolean   @default(false)

  @@unique([jobId, handymanId])
  @@index([jobId])
  @@index([handymanId])
  @@index([status])
}

enum BidStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

model JobInvitation {
  id          String    @id @default(cuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  handymanId  String
  handyman    User      @relation("HandymanInvitations", fields: [handymanId], references: [id], onDelete: Cascade)
  message     String?   @db.Text
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([jobId, handymanId])
  @@index([handymanId, createdAt])
  @@index([jobId])
}

model Message {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  bidId     String?
  bid       Bid?     @relation(fields: [bidId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([bidId])
  @@index([bidId, createdAt])
}

model Review {
  id         String   @id @default(cuid())
  jobId      String   @unique
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  handymanId String
  handyman   User     @relation("ReviewsReceived", fields: [handymanId], references: [id], onDelete: Cascade)
  stars      Int // 1-5
  text       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([handymanId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String           @db.Text
  linkPath  String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, read])
}

enum NotificationType {
  BID_INVITATION
  NEW_BID
  BID_ACCEPTED
  BID_DECLINED
  JOB_COMPLETED
  NEW_MESSAGE
  JOB_STATUS
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  reason     String
  details    String?  @db.Text
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  role      String
  reason    String
  message   String   @db.Text
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailDelivery {
  id           String    @id @default(cuid())
  category     String
  recipient    String
  subject      String
  status       String    @default("PENDING")
  providerId   String?
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now())
  sentAt       DateTime?

  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

model CampaignEvent {
  id           String   @id @default(cuid())
  sessionId    String
  eventName    String
  campaign     String?
  referralCode String?
  path         String?
  zipCode      String?
  userId       String?
  jobId        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([eventName, createdAt])
  @@index([campaign])
  @@index([referralCode])
}

model SupportCase {
  id                 String           @id @default(cuid())
  sourceType         String           @default("CONTACT_SUBMISSION")
  sourceId           String           @unique
  senderName         String
  senderEmail        String
  audience           String
  category           String
  priority           String
  status             String           @default("NEEDS_REVIEW")
  subject            String?
  message            String           @db.Text
  summary            String           @db.Text
  desiredOutcome     String?          @db.Text
  missingInformation String?          @db.Text
  recommendedAction  String           @db.Text
  draftSubject       String?
  draftBody          String           @db.Text
  internalNote       String           @db.Text
  confidence         Float?
  escalated          Boolean          @default(false)
  processedByRunId   String?
  processedByRun     SupportAgentRun? @relation(fields: [processedByRunId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status, priority])
  @@index([senderEmail])
  @@index([createdAt])
}

model SupportAgentRun {
  id           String        @id @default(cuid())
  trigger      String
  status       String        @default("RUNNING")
  discovered   Int           @default(0)
  processed    Int           @default(0)
  failed       Int           @default(0)
  inputTokens  Int           @default(0)
  outputTokens Int           @default(0)
  errorMessage String?       @db.Text
  startedAt    DateTime      @default(now())
  finishedAt   DateTime?
  cases        SupportCase[]

  @@index([startedAt])
  @@index([status])
}

model SupportAgentSettings {
  id            String    @id @default("default")
  enabled       Boolean   @default(true)
  timezone      String    @default("America/New_York")
  firstRunHour  Int       @default(8)
  secondRunHour Int       @default(16)
  batchSize     Int       @default(20)
  model         String    @default("gpt-5-mini")
  lastRunAt     DateTime?
  updatedAt     DateTime  @updatedAt
}

model MarketplaceOpsSignal {
  id                String             @id @default(cuid())
  signalKey         String             @unique
  type              String
  priority          String
  status            String             @default("OPEN")
  subjectType       String
  subjectId         String?
  title             String
  summary           String             @db.Text
  recommendedAction String             @db.Text
  evidence          Json
  metricValue       Float?
  latestRunId       String?
  latestRun         MarketplaceOpsRun? @relation(fields: [latestRunId], references: [id], onDelete: SetNull)
  detectedAt        DateTime           @default(now())
  lastSeenAt        DateTime           @default(now())
  resolvedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status, priority])
  @@index([type, status])
  @@index([subjectType, subjectId])
  @@index([lastSeenAt])
}

model MarketplaceOpsRun {
  id           String                 @id @default(cuid())
  trigger      String
  status       String                 @default("RUNNING")
  detected     Int                    @default(0)
  created      Int                    @default(0)
  refreshed    Int                    @default(0)
  autoResolved Int                    @default(0)
  errorMessage String?                @db.Text
  snapshot     Json?
  startedAt    DateTime               @default(now())
  finishedAt   DateTime?
  signals      MarketplaceOpsSignal[]

  @@index([startedAt])
  @@index([status])
}

model MarketplaceOpsSettings {
  id                   String   @id @default("default")
  enabled              Boolean  @default(true)
  timezone             String   @default("America/New_York")
  runHour              Int      @default(7)
  noBidHours           Int      @default(24)
  lowBidHours          Int      @default(48)
  staleJobHours        Int      @default(168)
  awardedStaleHours    Int      @default(168)
  reviewGapHours       Int      @default(72)
  newHandymanGraceDays Int      @default(14)
  handymanInactiveDays Int      @default(30)
  lastRunAt            DateTime?
  updatedAt            DateTime @updatedAt
}