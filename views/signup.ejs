<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <title>Sign Up - FixMyHome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <%- include('partials/favicon-head') %>
</head>
<body class="site-body auth-body">
  <div class="auth-theme-toggle">
    <button type="button" class="btn btn-secondary" data-theme-toggle>Dark mode</button>
  </div>
  <main class="auth-shell auth-shell-wide">
    <section class="auth-hero">
      <p class="eyebrow">Two-sided marketplace</p>
      <h1>Set your budget or win the work.</h1>
      <p>Create a homeowner account to post a job, or join as a handyman to browse local work and submit bids.</p>
      <div class="auth-role-grid">
        <article class="mini-card">
          <h3>Homeowner</h3>
          <p>Post jobs, compare quotes, award one bid, mark work complete, and leave a review.</p>
        </article>
        <article class="mini-card">
          <h3>Handyman</h3>
          <p>Build a trust profile, browse matching work, bid once per job, and message before award.</p>
        </article>
      </div>
    </section>

    <section class="auth-card app-card">
      <div class="auth-card-head">
        <p class="eyebrow">Get started</p>
        <h2>Create account</h2>
      </div>
      <% if (flash) { %><div class="flash" role="alert"><%= flash %></div><% } %>
      <form method="POST" action="/signup" class="stack-form">
        <label>
          <span>Name</span>
          <input type="text" id="signup-name" name="name" value="<%= formData?.name || '' %>" class="<%= errors?.name ? 'input-error' : '' %>" aria-invalid="<%= errors?.name ? 'true' : 'false' %>" aria-describedby="<%= errors?.name ? 'signup-name-error' : '' %>" required />
          <% if (errors?.name) { %><small id="signup-name-error" class="field-help field-error" role="alert"><%= errors.name %></small><% } %>
        </label>
        <label>
          <span>Email</span>
          <input type="email" id="signup-email" name="email" value="<%= formData?.email || '' %>" class="<%= errors?.email ? 'input-error' : '' %>" aria-invalid="<%= errors?.email ? 'true' : 'false' %>" aria-describedby="signup-email-help<%= errors?.email ? ' signup-email-error' : '' %>" required data-email-hint-output="signup-email-help" />
          <% if (errors?.email) { %><small id="signup-email-error" class="field-help field-error" role="alert"><%= errors.email %></small><% } %>
          <small id="signup-email-help" class="field-help email-help" data-email-hint-tone="muted">We’ll use this email for login and password resets.</small>
        </label>
        <label>
          <span>Password</span>
          <div class="password-input-row">
            <input type="password" id="signup-password" name="password" minlength="8" class="<%= errors?.password ? 'input-error' : '' %>" aria-invalid="<%= errors?.password ? 'true' : 'false' %>" aria-describedby="signup-password-help signup-password-caps-help<%= errors?.password ? ' signup-password-error' : '' %>" required data-password-strength-input="signup-password-help" data-caps-lock-output="signup-password-caps-help" />
            <button type="button" class="btn btn-secondary btn-small password-toggle" data-password-toggle="signup-password">Show</button>
          </div>
          <% if (errors?.password) { %><small id="signup-password-error" class="field-help field-error" role="alert"><%= errors.password %></small><% } %>
          <small id="signup-password-help" class="field-help password-strength-help" data-password-strength-tone="muted"></small>
          <small class="field-help">Use 8+ characters and include at least 3 of these: uppercase, lowercase, number, symbol.</small>
          <small id="signup-password-caps-help" class="field-help caps-lock-help" data-caps-lock-tone="muted">Caps lock is off.</small>
        </label>
        <label>
          <span>Confirm password</span>
          <div class="password-input-row">
            <input type="password" id="signup-confirm-password" name="confirmPassword" minlength="8" class="<%= errors?.confirmPassword ? 'input-error' : '' %>" aria-invalid="<%= errors?.confirmPassword ? 'true' : 'false' %>" aria-describedby="signup-password-match-help signup-confirm-password-caps-help<%= errors?.confirmPassword ? ' signup-confirm-password-error' : '' %>" required data-password-match-with="signup-password" data-password-match-output="signup-password-match-help" data-caps-lock-output="signup-confirm-password-caps-help" />
            <button type="button" class="btn btn-secondary btn-small password-toggle" data-password-toggle="signup-confirm-password">Show</button>
          </div>
          <% if (errors?.confirmPassword) { %><small id="signup-confirm-password-error" class="field-help field-error" role="alert"><%= errors.confirmPassword %></small><% } %>
          <small id="signup-password-match-help" class="field-help password-match-help" data-password-match-tone="muted">Re-enter your password to confirm it matches.</small>
          <small id="signup-confirm-password-caps-help" class="field-help caps-lock-help" data-caps-lock-tone="muted">Caps lock is off.</small>
        </label>
        <label>
          <span>Location</span>
          <input type="text" name="location" value="<%= formData?.location || '' %>" placeholder="City, state or ZIP" />
        </label>
        <fieldset class="role-picker <%= errors?.role ? 'role-picker-error' : '' %>" aria-invalid="<%= errors?.role ? 'true' : 'false' %>" aria-describedby="<%= errors?.role ? 'signup-role-error' : '' %>">
          <legend>Choose your role</legend>
          <label class="role-option">
            <input type="radio" name="role" value="HOMEOWNER" <%= formData?.role === 'HOMEOWNER' ? 'checked' : '' %> required />
            <span>
              <strong>Homeowner</strong>
              <small>I need help with projects around the house.</small>
            </span>
          </label>
          <label class="role-option">
            <input type="radio" name="role" value="HANDYMAN" <%= formData?.role === 'HANDYMAN' ? 'checked' : '' %> required />
            <span>
              <strong>Handyman</strong>
              <small>I want to find jobs and submit bids.</small>
            </span>
          </label>
          <% if (errors?.role) { %><small id="signup-role-error" class="field-help field-error" role="alert"><%= errors.role %></small><% } %>
        </fieldset>
        <button type="submit" class="btn btn-primary">Create account</button>
      </form>
      <p class="auth-switch">Already registered? <a href="/login">Log in</a>.</p>
    </section>
  </main>
  <%- include('partials/site-footer') %>
  <script src="/csrf-forms.js" defer></script>
  <script src="/auth-passwords.js" defer></script>
  <script src="/auth-accessibility.js" defer></script>
  <script src="/theme-toggle.js" defer></script>
</body>
</html>
