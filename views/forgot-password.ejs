<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <title>Forgot Password - FixMyHome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="site-body auth-body">
  <div class="auth-theme-toggle">
    <button type="button" class="btn btn-secondary" data-theme-toggle>Dark mode</button>
  </div>
  <main class="auth-shell">
    <section class="auth-hero">
      <p class="eyebrow">Password reset</p>
      <h1>Get back into your account.</h1>
      <p>Enter the email tied to your FixMyHome account and we’ll generate a secure reset link.</p>
      <ul class="auth-highlights">
        <li>Reset links expire after 1 hour</li>
        <li>Only the newest active link will work</li>
        <li>If SMTP is configured, FixMyHome sends the reset link by email</li>
        <li>If SMTP is not configured yet, the link is written to the server log for local use</li>
      </ul>
      <a href="/login" class="text-link">Back to login</a>
    </section>

    <section class="auth-card app-card">
      <div class="auth-card-head">
        <p class="eyebrow">Need help signing in?</p>
        <h2>Forgot password</h2>
      </div>
      <% if (flash) { %><div class="flash" role="alert"><%= flash %></div><% } %>
      <% if (message) { %><div class="flash flash-success" role="status"><%= message %></div><% } %>
      <form method="POST" action="/forgot-password" class="stack-form">
        <label>
          <span>Email</span>
          <input type="email" id="forgot-password-email" name="email" value="<%= email || '' %>" class="<%= errors?.email ? 'input-error' : '' %>" aria-invalid="<%= errors?.email ? 'true' : 'false' %>" aria-describedby="forgot-password-email-help<%= errors?.email ? ' forgot-password-email-error' : '' %>" required data-email-hint-output="forgot-password-email-help" />
          <% if (errors?.email) { %><small id="forgot-password-email-error" class="field-help field-error" role="alert"><%= errors.email %></small><% } %>
          <small id="forgot-password-email-help" class="field-help email-help" data-email-hint-tone="muted">Enter the email you usually use to sign in.</small>
        </label>
        <button type="submit" class="btn btn-primary">Generate reset link</button>
      </form>
      <div class="review-display auth-reset-box">
        <strong>Email delivery</strong>
        <p>If SMTP is configured, the reset link is emailed. Otherwise, local development falls back to <code>server.out.log</code>.</p>
      </div>
      <p class="auth-switch">Remembered it? <a href="/login">Go back to login</a>.</p>
    </section>
  </main>
  <%- include('partials/site-footer') %>
  <script src="/csrf-forms.js" defer></script>
  <script src="/auth-passwords.js" defer></script>
  <script src="/auth-accessibility.js" defer></script>
  <script src="/theme-toggle.js" defer></script>
</body>
</html>
