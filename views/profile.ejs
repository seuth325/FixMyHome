<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <title>Profile - FixMyHome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <%- include('partials/favicon-head') %>
</head>
<body class="site-body app-body">
  <div class="app-shell">
    <header class="app-topbar app-card">
      <div>
        <a href="/dashboard" class="brand-mark" aria-label="Go to FixMyHome dashboard">FixMyHome</a>
        <h1>Profile settings</h1>
        <p class="topbar-copy topbar-copy-inline">
          <span><%= user.name %></span>
          <span>&middot;</span>
          <span><%= getRoleLabel(user.role) %></span>
          <% if (user.location) { %>
            <span>&middot;</span>
            <span><%= user.location %></span>
          <% } %>
        </p>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn btn-secondary">Back to dashboard</a>
        <form method="POST" action="/logout">
          <button type="submit" class="btn btn-primary">Log out</button>
        </form>
      </div>
    </header>

    <% if (flash) { %><div class="flash"><%= flash %></div><% } %>

    <% if (user.role === 'HOMEOWNER') { %>
      <section class="profile-grid">
        <article class="app-card">
          <div class="section-head">
            <div>
              <p class="eyebrow">Profile</p>
              <h2>Homeowner details</h2>
            </div>
            <span class="stat-pill"><%= roleData.jobCount %> jobs</span>
          </div>
          <form method="POST" action="/profile" class="stack-form">
            <label>
              <span>Name</span>
              <input type="text" name="name" value="<%= user.name %>" required />
            </label>
            <label>
              <span>Location</span>
              <input type="text" name="location" value="<%= user.location || '' %>" required />
            </label>
            <button type="submit" class="btn btn-primary">Save profile</button>
          </form>
        </article>

        <article class="app-card">
          <div class="danger-panel">
            <p class="eyebrow">Danger zone</p>
            <h3>Delete homeowner account</h3>
            <p><%= roleData.accountDeletion?.summary || 'We will remove your account and any safe-to-delete draft activity.' %></p>
            <% if (roleData.accountDeletion?.allowed) { %>
              <form method="POST" action="/account/delete" class="stack-form">
                <label>
                  <span>Type DELETE to confirm</span>
                  <input type="text" name="confirmation" placeholder="DELETE" required />
                </label>
                <button type="submit" class="btn btn-danger btn-small">Delete my account</button>
              </form>
            <% } else { %>
              <p class="job-meta"><strong>Delete blocked:</strong> <%= roleData.accountDeletion?.reason %></p>
            <% } %>
          </div>
        </article>
      </section>
    <% } %>

    <% if (user.role === 'HANDYMAN') { %>
      <section class="profile-grid">
        <article class="app-card profile-span-full">
          <div class="section-head">
            <div>
              <p class="eyebrow">Profile</p>
              <h2>Handyman trust profile</h2>
            </div>
            <span class="stat-pill"><%= roleData.awardedCount %> awarded</span>
          </div>
          <form method="POST" action="/profile" class="stack-form">
            <div class="form-grid two-col">
              <label>
                <span>Name</span>
                <input type="text" name="name" value="<%= user.name %>" required />
              </label>
              <label>
                <span>Business name</span>
                <input type="text" name="businessName" value="<%= roleData.profile?.businessName || '' %>" />
              </label>
            </div>
            <div class="form-grid three-col">
              <label>
                <span>Location</span>
                <input type="text" name="location" value="<%= user.location || '' %>" required />
              </label>
              <label>
                <span>Service radius (miles)</span>
                <input type="number" name="serviceRadius" min="1" value="<%= roleData.profile?.serviceRadius || 15 %>" required />
              </label>
              <label>
                <span>Hourly guideline</span>
                <input type="number" name="hourlyGuideline" min="1" value="<%= roleData.profile?.hourlyGuideline || '' %>" />
              </label>
            </div>
            <label>
              <span>Skills</span>
              <input type="text" name="skills" value="<%= roleData.profile?.skills?.join(', ') || '' %>" placeholder="Painting, drywall, TV mounting" />
            </label>
            <label>
              <span>Bio</span>
              <textarea name="bio" rows="3"><%= roleData.profile?.bio || '' %></textarea>
            </label>
            <button type="submit" class="btn btn-primary">Save profile</button>
          </form>
          <div class="trust-row trust-row-strong">
            <span><%= roleData.profile?.ratingCount ? roleData.profile.ratingAvg.toFixed(1) + ' average rating' : 'No ratings yet' %></span>
            <span><%= roleData.profile?.ratingCount || 0 %> review<%= roleData.profile?.ratingCount === 1 ? '' : 's' %></span>
          </div>
        </article>

        <article class="app-card profile-span-full">
          <div class="verification-grid">
            <section class="verification-card">
              <p class="eyebrow">Insurance review</p>
              <h3>Status: <%= formatVerificationStatus(roleData.profile?.insuranceStatus || 'NOT_SUBMITTED') %></h3>
              <p>Share policy or coverage details for admin review. This helps homeowners compare trusted pros before award.</p>
              <% if (roleData.profile?.insuranceAdminNotes) { %>
                <p><strong>Admin note:</strong> <%= roleData.profile.insuranceAdminNotes %></p>
              <% } %>
              <form method="POST" action="/profile/verification/insurance" class="stack-form">
                <label>
                  <span>Insurance details</span>
                  <textarea name="proofDetails" rows="3" required><%= roleData.profile?.insuranceProofDetails || '' %></textarea>
                </label>
                <button type="submit" class="btn btn-secondary btn-small">Submit insurance review</button>
              </form>
            </section>
            <section class="verification-card">
              <p class="eyebrow">License review</p>
              <h3>Status: <%= formatVerificationStatus(roleData.profile?.licenseStatus || 'NOT_SUBMITTED') %></h3>
              <p>Add license number, issuing state, or trade credential details so admins can verify your profile.</p>
              <% if (roleData.profile?.licenseAdminNotes) { %>
                <p><strong>Admin note:</strong> <%= roleData.profile.licenseAdminNotes %></p>
              <% } %>
              <form method="POST" action="/profile/verification/license" class="stack-form">
                <label>
                  <span>License details</span>
                  <textarea name="proofDetails" rows="3" required><%= roleData.profile?.licenseProofDetails || '' %></textarea>
                </label>
                <button type="submit" class="btn btn-secondary btn-small">Submit license review</button>
              </form>
            </section>
          </div>
        </article>

        <article class="app-card profile-span-full">
          <div class="danger-panel">
            <p class="eyebrow">Danger zone</p>
            <h3>Delete handyman account</h3>
            <p><%= roleData.accountDeletion?.summary || 'We will remove your account and any safe-to-delete bid activity.' %></p>
            <% if (roleData.accountDeletion?.allowed) { %>
              <form method="POST" action="/account/delete" class="stack-form">
                <label>
                  <span>Type DELETE to confirm</span>
                  <input type="text" name="confirmation" placeholder="DELETE" required />
                </label>
                <button type="submit" class="btn btn-danger btn-small">Delete my account</button>
              </form>
            <% } else { %>
              <p class="job-meta"><strong>Delete blocked:</strong> <%= roleData.accountDeletion?.reason %></p>
            <% } %>
          </div>
        </article>
      </section>
    <% } %>
  </div>
</body>
</html>
