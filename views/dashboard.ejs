<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <title>Dashboard - FixMyHome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <%- include('partials/favicon-head') %>
</head>
<body class="site-body app-body">
  <div class="app-shell">
    <header class="app-topbar app-card">
      <div>
        <a href="/dashboard" class="brand-mark" aria-label="Go to FixMyHome dashboard">FixMyHome</a>
        <h1><%= user.role === 'HOMEOWNER' ? 'Manage your home projects' : 'Win your next local job' %></h1>
                <p class="topbar-copy topbar-copy-inline">
          <span><%= user.name %></span>
          <span>&middot;</span>
          <span><%= getRoleLabel(user.role) %></span>
          <% if (user.location) { %>
            <span>&middot;</span>
            <span><%= user.location %></span>
          <% } %>
          <a href="/profile" class="btn btn-secondary btn-small topbar-profile-btn">Profile</a>
        </p>
      </div>
      <div class="topbar-actions">
        <button type="button" class="btn btn-secondary theme-toggle" data-theme-toggle>Dark mode</button>
        <form method="POST" action="/logout">
          <button type="submit" class="btn btn-primary">Log out</button>
        </form>
      </div>
    </header>

    <section class="notification-center app-card">
      <div class="section-head compact-section-head">
        <div>
          <p class="eyebrow">Notifications</p>
          <h2>Recent alerts</h2>
        </div>
        <div class="inline-actions compact-actions">
          <span class="stat-pill"><%= unreadNotificationCount %> unread</span>
          <% if (notifications.length > 0) { %>
            <form method="POST" action="/notifications/read-all">
              <button type="submit" class="btn btn-secondary btn-small">Mark all read</button>
            </form>
          <% } %>
        </div>
      </div>
      <% if (notifications.length === 0) { %>
        <div class="empty-state small">No notifications yet.</div>
      <% } %>
      <% if (notifications.length > 0) { %>
        <div class="notification-list">
          <% notifications.forEach((notification) => { %>
            <article class="notification-item <%= notification.isRead ? 'read' : 'unread' %>">
              <div>
                <strong><%= notification.title %></strong>
                <p><%= notification.body %></p>
                <small><%= new Date(notification.createdAt).toLocaleString() %></small>
              </div>
              <form method="POST" action="/notifications/<%= notification.id %>/read" class="notification-action">
                <button type="submit" class="btn btn-secondary btn-small"><%= notification.isRead ? 'Open' : 'Mark read' %></button>
              </form>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>


    <% if (flash) { %><div class="flash"><%= flash %></div><% } %>

    <% if (user.role === 'HOMEOWNER') { %>
      <% const homeownerFirstRun = roleData.jobCount === 0; %>
      <div class="dashboard-collapse-toolbar app-card">
        <div>
          <p class="eyebrow">Homeowner view</p>
          <h2>Collapse sections for faster scanning</h2>
        </div>
        <div class="inline-actions compact-actions">
          <button type="button" class="btn btn-secondary btn-small" data-dashboard-collapse-all>Collapse all</button>
          <button type="button" class="btn btn-secondary btn-small" data-dashboard-expand-all>Expand all</button>
        </div>
      </div>
      <section class="dashboard-grid homeowner-grid">
        <% if (homeownerFirstRun) { %>
          <article class="app-card span-three onboarding-card">
            <div class="section-head">
              <div>
                <p class="eyebrow">Getting Started</p>
                <h2>Post with confidence and attract better bids</h2>
                <p class="topbar-copy">You are one good job post away from getting clear quotes from local pros. We’ll help you make it specific, trustworthy, and easy to compare.</p>
              </div>
              <span class="stat-pill">3 quick steps</span>
            </div>
            <div class="welcome-step-grid">
              <section class="mini-guide-card">
                <strong>1. Describe the job simply</strong>
                <p>Start with the AI assistant in plain language. It can turn a rough note into a stronger title, category, description, and budget target.</p>
              </section>
              <section class="mini-guide-card">
                <strong>2. Add details that matter</strong>
                <p>Include photos, room or area details, and your preferred timing so handymen can bid accurately instead of guessing.</p>
              </section>
              <section class="mini-guide-card">
                <strong>3. Compare bids calmly</strong>
                <p>Once bids come in, you’ll be able to compare price, ETA, reviews, and verification before hiring anyone.</p>
              </section>
            </div>
          </article>
        <% } %>

<article class="app-card span-two">
          <div class="section-head">
            <div>
              <p class="eyebrow">Post a job</p>
              <h2>Create a request and attract bids</h2>
            </div>
            <span class="stat-pill"><%= roleData.activeCount %> active</span>
          </div>
          <form method="POST" action="/jobs" enctype="multipart/form-data" class="stack-form" id="homeowner-job-form">
            <section class="job-ai-panel" aria-labelledby="job-ai-title">
              <div class="section-head compact-section-head">
                <div>
                  <p class="eyebrow">AI Assistant</p>
                  <h3 id="job-ai-title">Turn a rough task note into a stronger job post</h3>
                </div>
                <span class="status-chip tone-neutral">Homeowner helper</span>
              </div>
              <label>
                <span>What needs done?</span>
                <textarea id="job-ai-prompt" rows="3" placeholder="Example: Need someone to patch two drywall holes in the guest room and repaint the wall this weekend."></textarea>
              </label>
              <div class="inline-actions compact-actions wrap-actions">
                <button type="button" class="btn btn-secondary btn-small" id="job-ai-draft-btn">Draft job post</button>
                <button type="button" class="btn btn-secondary btn-small" id="job-ai-polish-btn">Polish current details</button>
                <button type="button" class="btn btn-secondary btn-small" id="job-ai-budget-btn">Suggest budget + timing</button>
              </div>
              <div class="job-ai-chips" aria-label="Quick ideas">
                <button type="button" class="job-ai-chip" data-ai-prompt="Patch drywall and repaint a bedroom wall.">Wall repair</button>
                <button type="button" class="job-ai-chip" data-ai-prompt="Install two ceiling fans and check an old switch.">Electrical help</button>
                <button type="button" class="job-ai-chip" data-ai-prompt="Assemble a bed frame, dresser, and two nightstands.">Furniture assembly</button>
                <button type="button" class="job-ai-chip" data-ai-prompt="Fix a slow bathroom drain and a dripping faucet.">Plumbing fix</button>
              </div>
              <div class="job-ai-response" id="job-ai-response" hidden>
                <p class="job-ai-status" id="job-ai-status" aria-live="polite"></p>
                <p class="job-ai-summary" id="job-ai-summary"></p>
                <p class="job-meta" id="job-ai-budget-range"></p>
                <ul class="job-ai-checklist" id="job-ai-checklist"></ul>
              </div>
            </section>
            <div class="form-grid two-col">
              <label>
                <span>Title</span>
                <input type="text" id="job-title" name="title" required />
              </label>
              <label>
                <span>Category</span>
                <select id="job-category" name="category" required>
                  <option value="">Select category</option>
                  <% categories.forEach((category) => { %>
                    <option value="<%= category %>"><%= category %></option>
                  <% }) %>
                </select>
              </label>
            </div>
            <label>
              <span>Description</span>
              <textarea id="job-description" name="description" rows="4" required></textarea>
            </label>
            <div class="form-grid three-col">
              <label>
                <span>Location</span>
                <input type="text" id="job-location" name="location" value="<%= user.location || '' %>" required />
              </label>
              <label>
                <span>Target budget</span>
                <input type="number" id="job-budget" name="budget" min="1" required />
              </label>
              <label>
                <span>Preferred date window</span>
                <input type="text" id="job-preferred-date" name="preferredDate" placeholder="Mar 18-20 or weekends" />
              </label>
            </div>
            <label>
              <span>Photos</span>
              <input type="file" name="photos" accept="image/*" multiple />
              <small class="field-help">Upload up to 5 images, 5MB each.</small>
            </label>
            <div class="form-helper-panel">
              <strong>Helpful posting tips</strong>
              <p>Strong posts usually mention the room or area, what is already on site, and any urgency. Even one or two photos can lead to faster and more accurate bids.</p>
            </div>
            <button type="submit" class="btn btn-primary">Publish job</button>
          </form>
        </article>

        <article class="app-card span-three">
          <div class="section-head">
            <div>
              <p class="eyebrow">Your jobs</p>
              <h2>Compare bids, award work, and complete projects</h2>
            </div>
          </div>
          <% if (roleData.jobs.length === 0) { %>
            <div class="empty-state empty-state-rich">
              <strong>No jobs posted yet</strong>
              <p>Your first post usually takes just a few minutes. Start with a rough task note above and let the assistant help you fill in the rest.</p>
              <p class="job-meta">Example: “Need help mounting a TV in the living room and hiding the wires this weekend.”</p>
            </div>
          <% } %>
          <% roleData.jobs.forEach((job) => { %>
            <section class="job-card" data-job-card-id="homeowner-<%= job.id %>">
              <% const canEditJob = job.status === 'OPEN' && job.bids.length === 0; %>
              <div class="job-summary">
                <div>
                  <div class="job-title-row">
                    <h3><%= job.title %></h3>
                    <span class="status-chip tone-<%= getStatusTone(job.status) %>"><%= job.status.replace('_', ' ') %></span>
                  </div>
                  <p class="job-meta"><%= job.category %> ? <%= job.location %> ? Budget <%= formatCurrency(job.budget) %><% if (job.preferredDate) { %> ? <%= job.preferredDate %><% } %></p>
                  <p><%= job.description %></p>
                </div>
                <div class="action-stack compact-actions">
                  <% if (canEditJob) { %>
                    <a href="#edit-job-<%= job.id %>" class="btn btn-secondary btn-small">Edit post</a>
                    <form method="POST" action="/jobs/<%= job.id %>/delete">
                      <button type="submit" class="btn btn-secondary btn-small">Delete post</button>
                    </form>
                  <% } %>
                  <% if (job.status === 'OPEN') { %>
                    <form method="POST" action="/jobs/<%= job.id %>/status">
                      <input type="hidden" name="action" value="review" />
                      <button type="submit" class="btn btn-secondary btn-small">Move to In Review</button>
                    </form>
                  <% } %>
                  <% if (['OPEN', 'IN_REVIEW'].includes(job.status)) { %>
                    <form method="POST" action="/jobs/<%= job.id %>/invite" class="stack-form invite-bid-form">
                      <label>
                        <span>Invite handyman by email</span>
                        <input type="email" name="handymanEmail" placeholder="handyman@email.com" required />
                      </label>
                      <button type="submit" class="btn btn-secondary btn-small">Invite handyman</button>
                    </form>
                  <% } %>
                  <% if (job.status === 'AWARDED' && job.payment?.status === 'FUNDED') { %>
                    <form method="POST" action="/jobs/<%= job.id %>/status">
                      <input type="hidden" name="action" value="complete" />
                      <button type="submit" class="btn btn-primary btn-small">Mark complete</button>
                    </form>
                  <% } %>
                </div>
              </div>

              <% if (canEditJob) { %>
                <details class="job-edit-panel" id="edit-job-<%= job.id %>">
                  <summary>Edit this post before bids arrive</summary>
                  <form method="POST" action="/jobs/<%= job.id %>/edit" enctype="multipart/form-data" class="stack-form">
                    <div class="form-grid two-col">
                      <label>
                        <span>Title</span>
                        <input type="text" name="title" value="<%= job.title %>" required />
                      </label>
                      <label>
                        <span>Category</span>
                        <select name="category" required>
                          <option value="">Select category</option>
                          <% categories.forEach((category) => { %>
                            <option value="<%= category %>" <%= job.category === category ? 'selected' : '' %>><%= category %></option>
                          <% }) %>
                        </select>
                      </label>
                    </div>
                    <label>
                      <span>Description</span>
                      <textarea name="description" rows="3" required><%= job.description %></textarea>
                    </label>
                    <div class="form-grid three-col">
                      <label>
                        <span>Location</span>
                        <input type="text" name="location" value="<%= job.location %>" required />
                      </label>
                      <label>
                        <span>Target budget</span>
                        <input type="number" name="budget" min="1" value="<%= job.budget %>" required />
                      </label>
                      <label>
                        <span>Preferred date window</span>
                        <input type="text" name="preferredDate" value="<%= job.preferredDate || '' %>" />
                      </label>
                    </div>
                    <label>
                      <span>Add more photos</span>
                      <input type="file" name="photos" accept="image/*" multiple />
                      <small class="field-help">This job has <%= job.photos.length %> of 5 photos used. Add more if needed before bids arrive.</small>
                    </label>
                    <% if (job.photos.length > 0) { %>
                      <div class="editable-photo-manager">
                        <strong>Current photos</strong>
                        <div class="photo-grid compact-photo-grid">
                          <% job.photos.forEach((photo, photoIndex) => { %>
                            <div class="editable-photo-card">
                              <a href="<%= photo.url %>" target="_blank" rel="noreferrer" class="photo-thumb-link">
                                <img src="<%= photo.url %>" alt="Photo <%= photoIndex + 1 %> for <%= job.title %>" class="photo-thumb" />
                              </a>
                              <div class="inline-actions compact-actions wrap-actions">
                                <form method="POST" action="/jobs/<%= job.id %>/photos/<%= photo.id %>/move">
                                  <input type="hidden" name="direction" value="left" />
                                  <button type="submit" class="btn btn-secondary btn-small" <%= photoIndex === 0 ? 'disabled' : '' %>>Move left</button>
                                </form>
                                <form method="POST" action="/jobs/<%= job.id %>/photos/<%= photo.id %>/move">
                                  <input type="hidden" name="direction" value="right" />
                                  <button type="submit" class="btn btn-secondary btn-small" <%= photoIndex === job.photos.length - 1 ? 'disabled' : '' %>>Move right</button>
                                </form>
                                <form method="POST" action="/jobs/<%= job.id %>/photos/<%= photo.id %>/delete">
                                  <button type="submit" class="btn btn-secondary btn-small">Remove photo</button>
                                </form>
                              </div>
                            </div>
                          <% }) %>
                        </div>
                      </div>
                    <% } %>
                    <div class="inline-actions compact-actions">
                      <button type="submit" class="btn btn-primary btn-small">Save updates</button>
                      <span class="job-meta">Editing locks once the first bid is submitted.</span>
                    </div>
                  </form>
                </details>
              <% } %>

              <% if (job.payment) { %>
                <div class="payment-panel">
                  <div>
                    <p class="eyebrow">Escrow</p>
                    <h4><%= formatCurrency(job.payment.amount) %> held for this job</h4>
                    <p class="muted">Status: <span class="status-chip tone-<%= getStatusTone(job.payment.status) %>"><%= formatPaymentStatus(job.payment.status) %></span></p>
                    <% if (job.dispute) { %>
                      <p class="muted">Dispute: <span class="status-chip tone-<%= getStatusTone(job.dispute.status === 'OPEN' ? 'DISPUTED' : job.payment.status) %>"><%= formatDisputeStatus(job.dispute.status) %></span> by <strong><%= job.dispute.openedBy?.name || 'Unknown user' %></strong></p>
                    <% } %>
                  </div>
                  <div class="action-stack compact-actions">
                    <% if (job.status === 'AWARDED' && job.payment.status === 'PENDING_FUNDING') { %>
                      <form method="POST" action="/jobs/<%= job.id %>/payment/fund">
                        <button type="submit" class="btn btn-primary btn-small">Fund escrow</button>
                      </form>
                    <% } %>
                    <% if (['AWARDED', 'COMPLETED'].includes(job.status) && job.payment.status === 'FUNDED' && (!job.dispute || job.dispute.status !== 'OPEN')) { %>
                      <form method="POST" action="/jobs/<%= job.id %>/disputes" class="stack-form dispute-inline-form">
                        <input type="hidden" name="reason" value="Scope or quality concern" />
                        <input type="hidden" name="details" value="Homeowner opened a dispute from the escrow panel." />
                        <button type="submit" class="btn btn-secondary btn-small">Open dispute hold</button>
                      </form>
                    <% } %>
                    <% if (job.status === 'COMPLETED' && job.payment.status === 'FUNDED' && (!job.dispute || job.dispute.status !== 'OPEN')) { %>
                      <form method="POST" action="/jobs/<%= job.id %>/payment/release">
                        <button type="submit" class="btn btn-primary btn-small">Release payment</button>
                      </form>
                    <% } %>
                  </div>
                </div>
                <% if (job.dispute) { %>
                  <div class="dispute-panel">
                    <div class="section-head compact-section-head">
                      <div>
                        <p class="eyebrow">Dispute center</p>
                        <h4><%= job.dispute.reason %></h4>
                      </div>
                      <span class="status-chip tone-<%= getStatusTone(job.dispute.status === 'OPEN' ? 'DISPUTED' : job.payment?.status) %>"><%= formatDisputeStatus(job.dispute.status) %></span>
                    </div>
                    <p><%= job.dispute.details %></p>
                    <% if (job.dispute.status === 'OPEN') { %>
                      <form method="POST" action="/disputes/<%= job.dispute.id %>/resolve" class="stack-form dispute-resolve-form">
                        <label>
                          <span>Resolution</span>
                          <select name="resolution" required>
                            <option value="">Choose one</option>
                            <option value="RELEASE_PAYMENT">Release payment to handyman</option>
                            <option value="REFUND_HOMEOWNER">Refund homeowner</option>
                          </select>
                        </label>
                        <label>
                          <span>Resolution notes</span>
                          <textarea name="resolutionNotes" rows="2" required></textarea>
                        </label>
                        <button type="submit" class="btn btn-primary btn-small">Resolve dispute</button>
                      </form>
                    <% } else { %>
                      <div class="review-display slim-review">
                        <strong><%= job.dispute.resolution === 'RELEASE_PAYMENT' ? 'Payment released' : 'Escrow refunded' %></strong>
                        <p><%= job.dispute.resolutionNotes %></p>
                      </div>
                    <% } %>
                  </div>
                <% } %>
              <% } %>

              <% if (job.photos.length > 0) { %>
                <div class="photo-grid">
                  <% job.photos.forEach((photo) => { %>
                    <a href="<%= photo.url %>" target="_blank" rel="noreferrer" class="photo-thumb-link">
                      <img src="<%= photo.url %>" alt="Photo for <%= job.title %>" class="photo-thumb" />
                    </a>
                  <% }) %>
                </div>
              <% } %>

              <div class="bid-list">
                <% if (job.bids.length === 0) { %>
                  <div class="empty-state small empty-state-rich">
                    <strong>No bids yet</strong>
                    <p>That’s normal for a fresh post. More specific descriptions, realistic timing, and photos usually help pros respond faster.</p>
                  </div>
                <% } %>
                <% let recommendedBid = null; %>
                <% let recommendedReason = 'Good overall balance of price, timing, and trust.'; %>
                <% if (job.bids.length > 0) { %>
                  <% const bidAmounts = job.bids.map((entry) => entry.amount); %>
                  <% const bidEtas = job.bids.map((entry) => entry.etaDays); %>
                  <% const activeBidEntries = job.bids.filter((entry) => entry.handyman); %>
                  <% const ratedBids = activeBidEntries.filter((entry) => entry.handyman?.handymanProfile?.ratingCount); %>
                  <% const bestRatedValue = ratedBids.length ? Math.max(...ratedBids.map((entry) => entry.handyman.handymanProfile.ratingAvg)) : null; %>
                  <% const recommendationPool = activeBidEntries.map((entry) => {
                    const amountSpan = Math.max(...bidAmounts) - Math.min(...bidAmounts) || 1;
                    const etaSpan = Math.max(...bidEtas) - Math.min(...bidEtas) || 1;
                    const ratingValue = entry.handyman.handymanProfile?.ratingCount ? entry.handyman.handymanProfile.ratingAvg : 0;
                    const verifiedBonus = ['APPROVED'].includes(entry.handyman.handymanProfile?.insuranceStatus || '') || ['APPROVED'].includes(entry.handyman.handymanProfile?.licenseStatus || '') ? 0.5 : 0;
                    const shortlistBonus = entry.status === 'SHORTLISTED' ? 0.15 : 0;
                    const normalizedPrice = 1 - ((entry.amount - Math.min(...bidAmounts)) / amountSpan);
                    const normalizedEta = 1 - ((entry.etaDays - Math.min(...bidEtas)) / etaSpan);
                    return {
                      id: entry.id,
                      score: (normalizedPrice * 0.35) + (normalizedEta * 0.25) + ((ratingValue / 5) * 0.25) + verifiedBonus + shortlistBonus,
                      amount: entry.amount,
                      etaDays: entry.etaDays,
                      ratingValue,
                      verified: verifiedBonus > 0,
                    };
                  }); %>
                  <% recommendedBid = recommendationPool.sort((left, right) => right.score - left.score)[0]; %>
                  <% if (recommendedBid) {
                    if (recommendedBid.verified && recommendedBid.ratingValue >= 4.5) {
                      recommendedReason = 'Best balance of trust and strong reviews.';
                    } else if (recommendedBid.amount === Math.min(...bidAmounts) && recommendedBid.etaDays === Math.min(...bidEtas)) {
                      recommendedReason = 'Strong value with one of the fastest timelines.';
                    } else if (recommendedBid.amount === Math.min(...bidAmounts)) {
                      recommendedReason = 'Lowest price while staying competitive on timing.';
                    } else if (recommendedBid.etaDays === Math.min(...bidEtas)) {
                      recommendedReason = 'Fastest arrival with a solid overall fit.';
                    }
                  } %>
                  <div class="bid-compare-summary">
                    <div class="mini-stat-box">
                      <strong><%= job.bids.length %> active bid<%= job.bids.length === 1 ? '' : 's' %></strong>
                      <span><%= formatCurrency(Math.min(...bidAmounts)) %> to <%= formatCurrency(Math.max(...bidAmounts)) %></span>
                    </div>
                    <div class="mini-stat-box">
                      <strong>Fastest ETA</strong>
                      <span><%= Math.min(...bidEtas) %> day<%= Math.min(...bidEtas) === 1 ? '' : 's' %></span>
                    </div>
                    <div class="mini-stat-box">
                      <strong>Top rating</strong>
                      <span><%= bestRatedValue !== null ? `${bestRatedValue.toFixed(1)} stars` : 'New pros in this set' %></span>
                    </div>
                  </div>
                  <% if (recommendedBid) { %>
                    <div class="bid-recommendation-banner">
                      <div>
                        <p class="eyebrow">Recommended pick</p>
                        <strong><%= job.bids.find((entry) => entry.id === recommendedBid.id)?.handyman?.handymanProfile?.businessName || job.bids.find((entry) => entry.id === recommendedBid.id)?.handyman?.name || 'Former handyman' %></strong>
                        <p><%= recommendedReason %></p>
                      </div>
                      <span class="status-chip tone-success">Best overall fit</span>
                    </div>
                  <% } %>
                <% } %>
                <% job.bids.forEach((bid) => { %>
                  <% const lowestPrice = Math.min(...job.bids.map((entry) => entry.amount)); %>
                  <% const fastestEta = Math.min(...job.bids.map((entry) => entry.etaDays)); %>
                  <% const ratedBidSet = job.bids.filter((entry) => entry.handyman?.handymanProfile?.ratingCount); %>
                  <% const topRating = ratedBidSet.length ? Math.max(...ratedBidSet.map((entry) => entry.handyman.handymanProfile.ratingAvg)) : null; %>
                  <% const isLowestPrice = bid.amount === lowestPrice; %>
                  <% const isFastest = bid.etaDays === fastestEta; %>
                  <% const isBestRated = topRating !== null && bid.handyman?.handymanProfile?.ratingCount && bid.handyman.handymanProfile.ratingAvg === topRating; %>
                  <% const isVerified = ['APPROVED'].includes(bid.handyman?.handymanProfile?.insuranceStatus || '') || ['APPROVED'].includes(bid.handyman?.handymanProfile?.licenseStatus || ''); %>
                  <% const isRecommended = recommendedBid && bid.id === recommendedBid.id; %>
                  <article class="bid-card <%= bid.status === 'ACCEPTED' ? 'bid-card-accepted' : '' %> <%= isRecommended ? 'bid-card-recommended' : '' %>">
                    <div class="bid-compare-chips">
                      <% if (isRecommended) { %><span class="status-chip tone-success">Recommended pick</span><% } %>
                      <% if (isLowestPrice) { %><span class="status-chip tone-success">Lowest price</span><% } %>
                      <% if (isFastest) { %><span class="status-chip tone-review">Fastest</span><% } %>
                      <% if (isBestRated) { %><span class="status-chip tone-neutral">Best rated</span><% } %>
                      <% if (isVerified) { %><span class="status-chip tone-success">Verified</span><% } %>
                      <% if (bid.status === 'SHORTLISTED') { %><span class="status-chip tone-review">Short-listed</span><% } %>
                    </div>
                    <div class="bid-header">
                      <div>
                        <h4><%= bid.handyman?.handymanProfile?.businessName || bid.handyman?.name || 'Former handyman' %></h4>
                        <p class="job-meta"><%= bid.handyman?.name || 'Former handyman' %> ? <%= bid.handyman?.location || 'Location pending' %></p>
                      </div>
                      <div class="bid-numbers">
                        <strong><%= formatCurrency(bid.amount) %></strong>
                        <span><%= bid.etaDays %> day<%= bid.etaDays === 1 ? '' : 's' %></span>
                        <span class="status-chip tone-<%= getStatusTone(bid.status) %>"><%= bid.status %></span>
                      </div>
                    </div>
                    <div class="bid-compare-grid">
                      <div class="mini-stat-box">
                        <strong>Quote</strong>
                        <span><%= formatCurrency(bid.amount) %></span>
                      </div>
                      <div class="mini-stat-box">
                        <strong>ETA</strong>
                        <span><%= bid.etaDays %> day<%= bid.etaDays === 1 ? '' : 's' %></span>
                      </div>
                      <div class="mini-stat-box">
                        <strong>Rating</strong>
                        <span><%= bid.handyman?.handymanProfile?.ratingCount ? bid.handyman.handymanProfile.ratingAvg.toFixed(1) + ' stars' : 'New pro' %></span>
                      </div>
                      <div class="mini-stat-box">
                        <strong>Trust</strong>
                        <span><%= isVerified ? 'At least one approved verification' : 'Verification pending' %></span>
                      </div>
                    </div>
                    <p><%= bid.message %></p>
                    <div class="trust-row">
                      <span><%= bid.handyman?.handymanProfile?.ratingCount ? bid.handyman.handymanProfile.ratingAvg.toFixed(1) + ' stars' : 'New pro' %></span>
                      <span>Insurance: <%= formatVerificationStatus(bid.handyman?.handymanProfile?.insuranceStatus || 'NOT_SUBMITTED') %></span>
                      <span>License: <%= formatVerificationStatus(bid.handyman?.handymanProfile?.licenseStatus || 'NOT_SUBMITTED') %></span>
                    </div>
                    <div class="action-stack inline-actions">
                      <% if (!['AWARDED', 'COMPLETED'].includes(job.status) && bid.status !== 'ACCEPTED') { %>
                        <form method="POST" action="/bids/<%= bid.id %>/shortlist">
                          <button type="submit" class="btn btn-secondary btn-small">Short-list</button>
                        </form>
                        <form method="POST" action="/bids/<%= bid.id %>/accept">
                          <button type="submit" class="btn btn-primary btn-small">Accept bid</button>
                        </form>
                      <% } %>
                      <% if (bid.handyman) { %>
                        <form method="POST" action="/users/<%= bid.handyman.id %>/report">
                          <input type="hidden" name="reason" value="Bidder trust concern" />
                          <input type="hidden" name="details" value="Homeowner reported this handyman from the bid comparison view." />
                          <button type="submit" class="btn btn-secondary btn-small">Report user</button>
                        </form>
                      <% } %>
                    </div>
                    <div class="message-thread">
                      <% if (bid.messages.length === 0) { %>
                        <p class="muted">No messages yet.</p>
                      <% } %>
                      <% bid.messages.forEach((message) => { %>
                        <div class="message-bubble <%= message.senderId === user.id ? 'mine' : '' %>">
                          <strong><%= message.sender?.name || 'Former user' %></strong>
                          <span><%= new Date(message.createdAt).toLocaleString() %></span>
                          <p><%= message.body %></p>
                        </div>
                      <% }) %>
                      <form method="POST" action="/bids/<%= bid.id %>/messages" class="message-form">
                        <textarea name="body" rows="2" placeholder="Ask a question or confirm details"></textarea>
                        <button type="submit" class="btn btn-secondary btn-small">Send</button>
                      </form>
                    </div>
                  </article>
                <% }) %>
              </div>

              <% if (job.status === 'COMPLETED' && !job.review && job.acceptedBidId && job.payment?.status === 'RELEASED') { %>
                <form method="POST" action="/jobs/<%= job.id %>/reviews" class="review-form">
                  <h4>Leave a review</h4>
                  <div class="form-grid review-grid">
                    <label>
                      <span>Stars</span>
                      <select name="stars" required>
                        <option value="">Select</option>
                        <option value="5">5</option>
                        <option value="4">4</option>
                        <option value="3">3</option>
                        <option value="2">2</option>
                        <option value="1">1</option>
                      </select>
                    </label>
                    <label class="review-text">
                      <span>Review</span>
                      <textarea name="text" rows="2" required></textarea>
                    </label>
                  </div>
                  <button type="submit" class="btn btn-primary btn-small">Submit review</button>
                </form>
              <% } %>

              <% if (job.review) { %>
                <div class="review-display">
                  <strong><%= job.review.stars %>/5 stars</strong>
                  <p><%= job.review.text %></p>
                </div>
              <% } %>
            </section>
          <% }) %>
</article>
      </section>
    <% } else { %>
      <% const handymanFirstRun = roleData.myBids.length === 0 && roleData.awardedCount === 0; %>
      <div class="dashboard-collapse-toolbar app-card">
        <div>
          <p class="eyebrow">Handyman view</p>
          <h2>Collapse sections for faster scanning</h2>
        </div>
        <div class="inline-actions compact-actions">
          <button type="button" class="btn btn-secondary btn-small" data-dashboard-collapse-all>Collapse all</button>
          <button type="button" class="btn btn-secondary btn-small" data-dashboard-expand-all>Expand all</button>
        </div>
      </div>
      <section class="dashboard-grid handyman-grid">
        <% if (handymanFirstRun) { %>
          <article class="app-card span-four onboarding-card">
            <div class="section-head">
              <div>
                <p class="eyebrow">Getting Started</p>
                <h2>Set up your profile and start winning local jobs</h2>
                <p class="topbar-copy">A complete trust profile and a focused first bid usually make the biggest difference. We’ve highlighted the best first steps below.</p>
              </div>
              <span class="stat-pill">3 quick steps</span>
            </div>
            <div class="welcome-step-grid">
              <section class="mini-guide-card">
                <strong>1. Finish your trust profile</strong>
                <p>Add skills, service radius, pricing guidance, and a short bio so homeowners know what kind of work you do best.</p>
              </section>
              <section class="mini-guide-card">
                <strong>2. Submit verification details</strong>
                <p>Insurance and license details help you stand out when homeowners compare similar bids.</p>
              </section>
              <section class="mini-guide-card">
                <strong>3. Bid on well-matched jobs first</strong>
                <p>Start with nearby jobs in your strongest categories and explain your approach clearly in the message box.</p>
              </section>
            </div>
          </article>
        <% } %>

<article class="app-card span-two">
          <div class="section-head">
            <div>
              <p class="eyebrow">Billing</p>
              <h2>Choose a plan that fits your pipeline</h2>
            </div>
            <span class="stat-pill"><%= roleData.billing.planSummary.unlimitedBids ? 'Unlimited' : roleData.billing.planSummary.leadCredits + ' credits' %></span>
          </div>
          <div class="billing-credit-row">
            <div class="mini-stat-box wide-stat-box">
              <strong><%= formatSubscriptionPlan(roleData.billing.planSummary.key) %> plan</strong>
              <span>Status: <%= formatBillingStatus(roleData.billing.planSummary.billingStatus) %> � Quantity <%= roleData.billing.planSummary.billingQuantity || 1 %><% if (roleData.billing.planSummary.billingPeriodEndsAt) { %> � Period ends <%= new Date(roleData.billing.planSummary.billingPeriodEndsAt).toLocaleDateString() %><% } else if (roleData.billing.planSummary.renewsAt) { %> � Renews <%= new Date(roleData.billing.planSummary.renewsAt).toLocaleDateString() %><% } %></span>
            </div>
            <div class="inline-actions compact-actions">
              <% if (paymentProvider === 'stripe' && roleData.billing.planSummary.hasCustomer) { %>
                <form method="POST" action="/billing/portal">
                  <button type="submit" class="btn btn-secondary btn-small">Manage billing</button>
                </form>
              <% } %>
              <form method="POST" action="/billing/credits">
                <input type="hidden" name="pack" value="STARTER" />
                <button type="submit" class="btn btn-secondary btn-small">Buy 5 credits</button>
              </form>
              <form method="POST" action="/billing/credits">
                <input type="hidden" name="pack" value="GROWTH" />
                <button type="submit" class="btn btn-secondary btn-small">Buy 15 credits</button>
              </form>
            </div>
          </div>
          <% if (paymentProvider === 'stripe') { %>
            <p class="muted">Paid plans run through Stripe Checkout and stay managed from the customer portal after activation.</p>
          <% } %>
          <div class="billing-plan-grid">
            <% Object.entries(planConfig).forEach(([planKey, plan]) => { %>
              <section class="billing-plan-card <%= roleData.billing.planSummary.key === planKey ? 'active' : '' %>">
                <p class="eyebrow"><%= plan.name %></p>
                <h3><%= plan.unlimitedBids ? 'Unlimited bidding' : plan.monthlyCredits + ' included credits' %></h3>
                <p><%= planKey === 'FREE' ? 'Best for occasional side work.' : planKey === 'PLUS' ? 'Best for steady weekly bidding.' : 'Best for full-time crews who never want to pause.' %></p>
                <form method="POST" action="/billing/plan">
                  <input type="hidden" name="plan" value="<%= planKey %>" />
                  <button type="submit" class="btn <%= roleData.billing.planSummary.key === planKey ? 'btn-secondary' : 'btn-primary' %> btn-small"><%= roleData.billing.planSummary.key === planKey ? 'Current plan' : plan.cta %></button>
                </form>
              </section>
            <% }) %>
          </div>
          <div class="billing-credit-row">
            <div class="mini-stat-box wide-stat-box">
              <strong><%= roleData.billing.planSummary.unlimitedBids ? 'Unlimited active' : roleData.billing.planSummary.leadCredits + ' lead credits left' %></strong>
              <span><%= roleData.billing.planSummary.renewsAt ? 'Renews ' + new Date(roleData.billing.planSummary.renewsAt).toLocaleDateString() : 'No paid renewal scheduled' %></span>
            </div>
          </div>
          <% if (roleData.billing.transactions.length > 0) { %>
            <div class="billing-history-list">
              <% roleData.billing.transactions.forEach((entry) => { %>
                <div class="billing-history-item">
                  <strong><%= entry.amount > 0 ? '+' + entry.amount : entry.amount %> credits</strong>
                  <span><%= entry.note %></span>
                  <small><%= new Date(entry.createdAt).toLocaleString() %></small>
                </div>
              <% }) %>
            </div>
          <% } %>
        </article>

        <article class="app-card span-four">
          <div class="section-head">
            <div>
              <p class="eyebrow">Your jobs</p>
              <h2>See funded work first, then pending, then completed</h2>
            </div>
          </div>
          <div class="billing-credit-row handyman-summary-row">
            <div class="mini-stat-box wide-stat-box">
              <strong><%= roleData.handymanJobSummary?.activeFunded || 0 %> active funded</strong>
              <span>Jobs with funded escrow and work ready to move.</span>
            </div>
            <div class="mini-stat-box wide-stat-box">
              <strong><%= roleData.handymanJobSummary?.pending || 0 %> pending</strong>
              <span>Bids still waiting on homeowner review or funding.</span>
            </div>
            <div class="mini-stat-box wide-stat-box">
              <strong><%= roleData.handymanJobSummary?.completed || 0 %> completed</strong>
              <span>Finished jobs with released payments or reviews.</span>
            </div>
          </div>
          <div class="saved-search-list jobs-filter-chip-row">
            <% roleData.handymanJobsViewOptions?.forEach((option) => { %>
              <a href="<%= option.href %>" class="saved-search-chip <%= option.active ? 'saved-search-chip-active' : '' %>">
                <%= option.label %> (<%= option.count %>)
              </a>
            <% }) %>
          </div>
          <% if (roleData.myBids.length === 0) { %>
            <div class="empty-state empty-state-rich">
              <strong>No bids yet</strong>
              <p>Your submitted quotes, homeowner messages, and award decisions will appear here once you start bidding.</p>
            </div>
          <% } %>
          <% if (roleData.myBids.length > 0 && (!roleData.handymanBidSections || roleData.handymanBidSections.length === 0)) { %>
            <div class="empty-state empty-state-rich">
              <strong>No jobs match this view</strong>
              <p>Try another quick filter to jump back to funded, pending, unread, or completed work.</p>
            </div>
          <% } %>
          <% (roleData.handymanBidSections || []).forEach((section) => { %>
            <section class="job-section">
              <div class="section-head compact-section-head">
                <div>
                  <p class="eyebrow"><%= section.title %></p>
                  <h3><%= section.bids.length %> job<%= section.bids.length === 1 ? '' : 's' %></h3>
                </div>
              </div>
              <p class="muted"><%= section.description %></p>
              <% section.bids.forEach((bid) => { %>
                <section class="job-card" data-job-card-id="handyman-<%= bid.id %>">
                  <div class="job-summary">
                    <div>
                      <div class="job-title-row">
                        <h3><%= bid.job.title %></h3>
                        <div class="inline-actions compact-actions">
                          <% if (bid.actionBadge) { %>
                            <span class="status-chip tone-<%= bid.actionBadge.tone %>"><%= bid.actionBadge.label %></span>
                          <% } %>
                          <span class="status-chip tone-<%= getStatusTone(bid.status) %>"><%= bid.status %></span>
                        </div>
                      </div>
                      <p class="job-meta">Homeowner: <%= bid.job.homeowner?.name || 'Former homeowner' %> ? <%= bid.job.location %> ? Budget <%= formatCurrency(bid.job.budget) %></p>
                      <% if (bid.latestMessage && bid.latestMessage.senderId !== user.id) { %>
                        <div class="trust-row location-match-row">
                          <span class="status-chip tone-review"><%= bid.replyWaitingCount === 1 ? '1 new homeowner message' : bid.replyWaitingCount + ' new homeowner messages' %></span>
                          <span>Latest: <%= bid.latestMessage.body.length > 96 ? bid.latestMessage.body.slice(0, 96) + '...' : bid.latestMessage.body %></span>
                        </div>
                      <% } %>
                      <p>Your quote: <strong><%= formatCurrency(bid.amount) %></strong> ? ETA <strong><%= bid.etaDays %> days</strong></p>
                      <% if (bid.job.payment && bid.status === 'ACCEPTED') { %>
                        <div class="trust-row payment-summary-row">
                          <span>Escrow <strong><%= formatCurrency(bid.job.payment.amount) %></strong></span>
                          <span class="status-chip tone-<%= getStatusTone(bid.job.payment.status) %>"><%= formatPaymentStatus(bid.job.payment.status) %></span>
                        </div>
                        <% if (!bid.job.dispute && bid.job.payment.status === 'FUNDED') { %>
                          <form method="POST" action="/jobs/<%= bid.job.id %>/disputes" class="stack-form dispute-inline-form">
                            <input type="hidden" name="reason" value="Change order or scope concern" />
                            <input type="hidden" name="details" value="Handyman opened a dispute from the awarded job panel." />
                            <button type="submit" class="btn btn-secondary btn-small">Open dispute</button>
                          </form>
                        <% } %>
                        <% if (bid.job.dispute) { %>
                          <div class="dispute-mini-card">
                            <strong>Dispute <%= formatDisputeStatus(bid.job.dispute.status) %></strong>
                            <p><%= bid.job.dispute.reason %> opened by <%= bid.job.dispute.openedBy?.name || 'Unknown user' %>.</p>
                            <% if (bid.job.dispute.status === 'RESOLVED' && bid.job.dispute.resolutionNotes) { %>
                              <p><%= bid.job.dispute.resolutionNotes %></p>
                            <% } %>
                            <form method="POST" action="/disputes/<%= bid.job.dispute.id %>/report" class="inline-actions compact-actions">
                              <input type="hidden" name="reason" value="Dispute escalation" />
                              <input type="hidden" name="details" value="Handyman escalated this dispute for admin review." />
                              <button type="submit" class="btn btn-secondary btn-small">Escalate dispute</button>
                            </form>
                          </div>
                        <% } %>
                      <% } %>
                      <p><%= bid.message %></p>
                    </div>
                    <% if (bid.job.review && bid.status === 'ACCEPTED') { %>
                      <div class="review-display slim-review">
                        <strong><%= bid.job.review.stars %>/5 stars</strong>
                        <p><%= bid.job.review.text %></p>
                      </div>
                    <% } %>
                  </div>
                  <% if (bid.job.photos.length > 0) { %>
                    <div class="photo-grid compact-photo-grid">
                      <% bid.job.photos.forEach((photo) => { %>
                        <a href="<%= photo.url %>" target="_blank" rel="noreferrer" class="photo-thumb-link">
                          <img src="<%= photo.url %>" alt="Photo for <%= bid.job.title %>" class="photo-thumb" />
                        </a>
                      <% }) %>
                    </div>
                  <% } %>
                  <div class="message-thread">
                    <% if (bid.messages.length === 0) { %>
                      <p class="muted">No messages yet.</p>
                    <% } %>
                    <% bid.messages.forEach((message) => { %>
                      <div class="message-bubble <%= message.senderId === user.id ? 'mine' : '' %>">
                        <strong><%= message.sender?.name || 'Former user' %></strong>
                        <span><%= new Date(message.createdAt).toLocaleString() %></span>
                        <p><%= message.body %></p>
                      </div>
                    <% }) %>
                    <% if (['PENDING', 'SHORTLISTED', 'ACCEPTED'].includes(bid.status)) { %>
                      <form method="POST" action="/bids/<%= bid.id %>/messages" class="message-form">
                        <textarea name="body" rows="2" placeholder="Send a quick update"></textarea>
                        <button type="submit" class="btn btn-secondary btn-small">Send</button>
                      </form>
                    <% } %>
                  </div>
                </section>
              <% }) %>
            </section>
          <% }) %>
        </article>

        <article class="app-card span-two">
          <div class="section-head">
            <div>
              <p class="eyebrow">Open jobs</p>
              <h2>Browse matching work and bid once per job</h2>
            </div>
            <span class="stat-pill"><%= roleData.openJobs.length %> open</span>
          </div>
          <% if (roleData.savedSearches?.length) { %>
            <div class="saved-searches-panel">
              <div class="saved-searches-head">
                <div>
                  <p class="eyebrow">Saved searches</p>
                  <h3>Reopen your favorite job views</h3>
                </div>
              </div>
              <div class="saved-search-list">
                <% roleData.savedSearches.forEach((savedSearch) => { %>
                  <div class="saved-search-chip-wrap">
                    <a href="<%= savedSearch.href %>" class="saved-search-chip"><%= savedSearch.name %></a>
                    <form method="POST" action="/saved-searches/<%= savedSearch.id %>/delete">
                      <button type="submit" class="chip-delete" aria-label="Delete <%= savedSearch.name %>">x</button>
                    </form>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
          <form method="GET" action="/dashboard" class="filter-panel">
            <div class="form-grid two-col">
              <label>
                <span>Search title, description, or location</span>
                <input type="text" name="search" value="<%= roleData.filters?.search || '' %>" placeholder="Paint, Columbus, TV mount" />
              </label>
              <label>
                <span>Category</span>
                <select name="category">
                  <option value="">All categories</option>
                  <% categories.forEach((category) => { %>
                    <option value="<%= category %>" <%= roleData.filters?.category === category ? 'selected' : '' %>><%= category %></option>
                  <% }) %>
                </select>
              </label>
            </div>
            <div class="form-grid five-col filter-row-grid">
              <label>
                <span>Min budget</span>
                <input type="number" name="minBudget" min="1" value="<%= roleData.filters?.minBudget || '' %>" />
              </label>
              <label>
                <span>Max budget</span>
                <input type="number" name="maxBudget" min="1" value="<%= roleData.filters?.maxBudget || '' %>" />
              </label>
              <label>
                <span>Sort</span>
                <select name="sort">
                  <option value="newest" <%= roleData.filters?.sort === 'newest' ? 'selected' : '' %>>Newest</option>
                  <option value="budget_asc" <%= roleData.filters?.sort === 'budget_asc' ? 'selected' : '' %>>Budget low to high</option>
                  <option value="budget_desc" <%= roleData.filters?.sort === 'budget_desc' ? 'selected' : '' %>>Budget high to low</option>
                </select>
              </label>
              <label class="checkbox-tile">
                <span>Only jobs with photos</span>
                <input type="checkbox" name="photosOnly" value="1" <%= roleData.filters?.photosOnly ? 'checked' : '' %> />
              </label>
              <label class="checkbox-tile">
                <span>Near my area only</span>
                <input type="checkbox" name="nearMeOnly" value="1" <%= roleData.filters?.nearMeOnly ? 'checked' : '' %> />
              </label>
            </div>
            <div class="inline-actions filter-actions">
              <button type="submit" class="btn btn-primary btn-small">Apply filters</button>
              <a href="/dashboard" class="btn btn-secondary btn-small">Reset</a>
            </div>
          </form>
          <form method="POST" action="/saved-searches" class="saved-search-form">
            <input type="hidden" name="search" value="<%= roleData.filters?.search || '' %>" />
            <input type="hidden" name="category" value="<%= roleData.filters?.category || '' %>" />
            <input type="hidden" name="minBudget" value="<%= roleData.filters?.minBudget || '' %>" />
            <input type="hidden" name="maxBudget" value="<%= roleData.filters?.maxBudget || '' %>" />
            <input type="hidden" name="sort" value="<%= roleData.filters?.sort || 'newest' %>" />
            <input type="hidden" name="photosOnly" value="<%= roleData.filters?.photosOnly ? '1' : '' %>" />
            <input type="hidden" name="nearMeOnly" value="<%= roleData.filters?.nearMeOnly ? '1' : '' %>" />
            <label>
              <span>Save this search</span>
              <input type="text" name="name" placeholder="Columbus painting jobs" required />
            </label>
            <button type="submit" class="btn btn-secondary btn-small">Save current filters</button>
          </form>
          <% if (roleData.openJobs.length === 0) { %>
            <div class="empty-state empty-state-rich">
              <strong>No open jobs match your current filters</strong>
              <p>Try widening your service area, clearing one filter, or saving a broader search for later.</p>
            </div>
          <% } %>
          <div class="job-feed-list">
            <% roleData.openJobs.forEach((job) => { %>
              <article class="job-feed-card">
                <div class="job-title-row">
                  <h3><%= job.title %></h3>
                  <span class="status-chip tone-<%= getStatusTone(job.status) %>"><%= job.status.replace('_', ' ') %></span>
                </div>
                <p class="job-meta"><%= job.category %> ? <%= job.location %> ? Budget <%= formatCurrency(job.budget) %><% if (job.preferredDate) { %> ? <%= job.preferredDate %><% } %></p>
                <div class="trust-row location-match-row">
                  <span class="status-chip tone-<%= job.locationMatch?.withinRadius ? 'success' : job.locationMatch?.score >= 1 ? 'review' : 'muted' %>"><%= job.locationMatch?.label || 'Location not matched' %></span>
                  <% if (job.locationMatch?.secondaryLabel) { %>
                    <span><%= job.locationMatch.secondaryLabel %></span>
                  <% } %>
                </div>
                <p><%= job.description %></p>
              <% if (job.photos.length > 0) { %>
                  <div class="photo-grid compact-photo-grid">
                    <% job.photos.forEach((photo) => { %>
                      <a href="<%= photo.url %>" target="_blank" rel="noreferrer" class="photo-thumb-link">
                        <img src="<%= photo.url %>" alt="Photo for <%= job.title %>" class="photo-thumb" />
                      </a>
                    <% }) %>
                  </div>
                <% } %>
                <% const existingBid = job.bids[0]; %>
                <form method="POST" action="/jobs/<%= job.id %>/bids" class="stack-form bid-submit-form" data-bid-assist-root data-job-id="<%= job.id %>">
                  <section class="job-ai-panel bid-ai-panel">
                    <div class="section-head compact-section-head">
                      <div>
                        <p class="eyebrow">AI Bid Coach</p>
                        <h4>Build a stronger quote</h4>
                      </div>
                      <span class="status-chip tone-neutral">Handyman helper</span>
                    </div>
                    <div class="inline-actions compact-actions wrap-actions">
                      <button type="button" class="btn btn-secondary btn-small" data-bid-assist-btn>Recommend quote</button>
                      <button type="button" class="btn btn-secondary btn-small" data-bid-polish-btn>Polish message</button>
                    </div>
                    <div class="job-ai-response" data-bid-assist-response hidden>
                      <p class="job-ai-status" data-bid-assist-status aria-live="polite"></p>
                      <p class="job-ai-summary" data-bid-assist-summary></p>
                      <p class="job-meta" data-bid-assist-range></p>
                      <ul class="job-ai-checklist" data-bid-assist-tips></ul>
                    </div>
                  </section>
                  <div class="form-grid three-col">
                    <label>
                      <span>Quote amount</span>
                      <input type="number" name="amount" min="1" value="<%= existingBid?.amount || '' %>" required data-bid-amount />
                    </label>
                    <label>
                      <span>ETA (days)</span>
                      <input type="number" name="etaDays" min="1" value="<%= existingBid?.etaDays || '' %>" required data-bid-eta />
                    </label>
                    <div class="mini-stat-box">
                      <strong><%= existingBid ? 'Bid saved' : 'No bid yet' %></strong>
                      <span><%= existingBid ? 'You can update it until award.' : roleData.billing.planSummary.unlimitedBids ? 'Unlimited bids on your plan.' : 'New bids use 1 lead credit.' %></span>
                    </div>
                  </div>
                  <label>
                    <span>Message</span>
                    <textarea name="message" rows="3" required data-bid-message><%= existingBid?.message || '' %></textarea>
                  </label>
                  <button type="submit" class="btn btn-primary btn-small"><%= existingBid ? 'Update bid' : 'Submit bid' %></button>
                </form>
                <form method="POST" action="/jobs/<%= job.id %>/report" class="inline-actions compact-actions">
                  <input type="hidden" name="reason" value="Job safety or fraud concern" />
                  <input type="hidden" name="details" value="Handyman reported this job from the open jobs feed." />
                  <button type="submit" class="btn btn-secondary btn-small">Report job</button>
                </form>
              </article>
            <% }) %>
          </div>
        </article>
      </section>
    <% } %>
  </div>
  <%- include('partials/site-footer') %>
  <script src="/csrf-forms.js" defer></script>
  <script src="/dashboard-ai.js" defer></script>
  <script src="/dashboard-layout.js" defer></script>
  <script src="/dashboard-job-cards.js" defer></script>
  <script src="/photo-fallback.js" defer></script>
  <script src="/theme-toggle.js" defer></script>
</body>
</html>









