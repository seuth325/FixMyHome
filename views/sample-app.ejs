<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sample App Preview - FixMyHome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <%- include('partials/favicon-head') %>
  <style>
    .sample-wrap {
      width: 100%;
      max-width: 1240px;
      margin: 0 auto;
      display: grid;
      gap: 20px;
    }
    .sample-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .sample-kpis {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .sample-kpi {
      padding: 14px;
      border-radius: 14px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
    }
    .sample-kpi strong {
      display: block;
      font-size: 1.75rem;
      margin-top: 4px;
    }
    .sample-card {
      padding: 16px;
      border-radius: 16px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
    }
    .sample-feed {
      display: grid;
      gap: 10px;
    }
    .sample-feed li {
      margin: 0;
      padding: 10px 12px;
      background: var(--surface-softest);
      border: 1px solid var(--border);
      border-radius: 10px;
      list-style: none;
    }
    @media (max-width: 980px) {
      .sample-grid { grid-template-columns: 1fr 1fr; }
      .sample-kpis { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 680px) {
      .sample-grid, .sample-kpis { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body class="site-body auth-body">
  <div class="auth-theme-toggle">
    <button type="button" class="btn btn-secondary" data-theme-toggle>Dark mode</button>
  </div>

  <main class="sample-wrap">
    <section class="app-card">
      <a href="/" class="brand-mark brand-mark-light" aria-label="Go to home">FixMyHome</a>
      <p class="eyebrow" style="margin-top:12px;">Sample canvas</p>
      <h1 style="margin: 6px 0 8px;">Side-by-side app preview page</h1>
      <p class="job-meta" style="margin:0;">Use this page to test UI ideas quickly before moving changes into the production dashboard.</p>
      <div class="inline-actions" style="margin-top:14px;">
        <a class="btn btn-primary" href="/dashboard">Open dashboard</a>
        <a class="btn btn-secondary" href="/">Landing page</a>
      </div>
    </section>

    <section class="app-card">
      <p class="eyebrow">Health overview</p>
      <h2 style="margin-top:4px;">At-a-glance sample metrics</h2>
      <div class="sample-kpis">
        <div class="sample-kpi"><span class="job-meta">Open jobs</span><strong>24</strong></div>
        <div class="sample-kpi"><span class="job-meta">New bids</span><strong>67</strong></div>
        <div class="sample-kpi"><span class="job-meta">Unread alerts</span><strong>3</strong></div>
        <div class="sample-kpi"><span class="job-meta">Paid this week</span><strong>$4.2k</strong></div>
      </div>
    </section>

    <section class="app-card">
      <p class="eyebrow">Module preview</p>
      <h2 style="margin-top:4px;">Reusable cards</h2>
      <div class="sample-grid">
        <article class="sample-card">
          <h3>Homeowner queue</h3>
          <p class="job-meta">Jobs waiting for first bid in your ZIP.</p>
          <button class="btn btn-secondary btn-small">Review queue</button>
        </article>
        <article class="sample-card">
          <h3>Handyman queue</h3>
          <p class="job-meta">Best-fit jobs based on category and distance.</p>
          <button class="btn btn-secondary btn-small">View matches</button>
        </article>
        <article class="sample-card">
          <h3>Billing queue</h3>
          <p class="job-meta">Subscriptions due, renewals, and checkout health.</p>
          <button class="btn btn-secondary btn-small">Open billing</button>
        </article>
      </div>
    </section>

    <section class="app-card">
      <p class="eyebrow">Activity stream</p>
      <h2 style="margin-top:4px;">Recent events</h2>
      <ul class="sample-feed">
        <li>New account created: homeowner in ZIP 33777</li>
        <li>Payment succeeded: Plus plan renewal</li>
        <li>Invite sent: Handyman invited to bid on Kitchen Repair</li>
      </ul>
    </section>
  </main>

  <%- include('partials/site-footer', { footerNavItems: legalNavItems, showFooterSupportEmail: false }) %>
  <script src="/theme-toggle.js" defer></script>
</body>
</html>
