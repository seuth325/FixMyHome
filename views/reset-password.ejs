<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <title>Reset Password - FixMyHome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="site-body auth-body">
  <div class="auth-theme-toggle">
    <button type="button" class="btn btn-secondary" data-theme-toggle>Dark mode</button>
  </div>
  <main class="auth-shell">
    <section class="auth-hero">
      <p class="eyebrow">Reset password</p>
      <h1>Choose a new password.</h1>
      <p>Use 8+ characters and include at least 3 of these: uppercase, lowercase, number, symbol. Once saved, your old reset link stops working.</p>
      <a href="/login" class="text-link">Back to login</a>
    </section>

    <section class="auth-card app-card">
      <div class="auth-card-head">
        <p class="eyebrow">Secure reset</p>
        <h2>Set new password</h2>
      </div>
      <% if (flash) { %><div class="flash" role="alert"><%= flash %></div><% } %>
      <% if (!tokenValid) { %>
        <div class="flash" role="alert">This reset link is invalid or has expired.</div>
        <p class="auth-switch"><a href="/forgot-password">Request a new reset link</a>.</p>
      <% } else { %>
        <form method="POST" action="/reset-password/<%= token %>" class="stack-form">
          <label>
            <span>New password</span>
            <div class="password-input-row">
              <input type="password" id="reset-password" name="password" minlength="8" class="<%= errors?.password ? 'input-error' : '' %>" aria-invalid="<%= errors?.password ? 'true' : 'false' %>" aria-describedby="reset-password-help reset-password-caps-help<%= errors?.password ? ' reset-password-error' : '' %>" required data-password-strength-input="reset-password-help" data-caps-lock-output="reset-password-caps-help" />
              <button type="button" class="btn btn-secondary btn-small password-toggle" data-password-toggle="reset-password">Show</button>
            </div>
            <% if (errors?.password) { %><small id="reset-password-error" class="field-help field-error" role="alert"><%= errors.password %></small><% } %>
            <small id="reset-password-help" class="field-help password-strength-help" data-password-strength-tone="muted"></small>
            <small class="field-help">Use 8+ characters and include at least 3 of these: uppercase, lowercase, number, symbol.</small>
            <small id="reset-password-caps-help" class="field-help caps-lock-help" data-caps-lock-tone="muted">Caps lock is off.</small>
          </label>
          <label>
            <span>Confirm new password</span>
            <div class="password-input-row">
              <input type="password" id="reset-confirm-password" name="confirmPassword" minlength="8" class="<%= errors?.confirmPassword ? 'input-error' : '' %>" aria-invalid="<%= errors?.confirmPassword ? 'true' : 'false' %>" aria-describedby="reset-password-match-help reset-confirm-password-caps-help<%= errors?.confirmPassword ? ' reset-confirm-password-error' : '' %>" required data-password-match-with="reset-password" data-password-match-output="reset-password-match-help" data-caps-lock-output="reset-confirm-password-caps-help" />
              <button type="button" class="btn btn-secondary btn-small password-toggle" data-password-toggle="reset-confirm-password">Show</button>
            </div>
            <% if (errors?.confirmPassword) { %><small id="reset-confirm-password-error" class="field-help field-error" role="alert"><%= errors.confirmPassword %></small><% } %>
            <small id="reset-password-match-help" class="field-help password-match-help" data-password-match-tone="muted">Re-enter your password to confirm it matches.</small>
            <small id="reset-confirm-password-caps-help" class="field-help caps-lock-help" data-caps-lock-tone="muted">Caps lock is off.</small>
          </label>
          <button type="submit" class="btn btn-primary">Save new password</button>
        </form>
      <% } %>
    </section>
  </main>
  <%- include('partials/site-footer') %>
  <script src="/csrf-forms.js" defer></script>
  <script src="/auth-passwords.js" defer></script>
  <script src="/auth-accessibility.js" defer></script>
  <script src="/theme-toggle.js" defer></script>
</body>
</html>
