# Copy this file to .env on the Hostinger VPS and fill in real values.
# Never commit the real .env file.

# App
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://fixmyhome.pro"

# Auth.js
AUTH_URL="https://fixmyhome.pro"
AUTH_TRUST_HOST="true"
AUTH_SECRET="replace-with-output-from-openssl-rand-base64-33"

# Database
# Option A: use the MySQL container in docker-compose.yml.
MYSQL_PASSWORD="replace-with-a-long-random-password"
DATABASE_URL="mysql://fixmyhome:replace-with-a-long-random-password@db:3306/fixmyhome"

# Option B: use a Hostinger-managed MySQL database instead.
# DATABASE_URL="mysql://hostinger_db_user:hostinger_db_password@hostinger_db_host:3306/hostinger_db_name"

# Uploadthing
UPLOADTHING_SECRET="sk_live_replace_me"
UPLOADTHING_APP_ID="replace_me"

# Optional AI recommendations
ANTHROPIC_API_KEY=""

# Password reset email delivery
MAIL_FROM="FixMyHome <noreply@fixmyhome.pro>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""