{
    "name":  "fixmyhome-web",
    "version":  "1.0.0",
    "private":  true,
    "description":  "Multi-user FixMyHome web app",
    "main":  "src/server.js",
    "scripts":  {
                    "start":  "node src/server.js",
                    "dev":  "node --watch src/server.js",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "prisma migrate dev",
                    "prisma:deploy":  "prisma migrate deploy",
                    "db:push":  "prisma db push --accept-data-loss",
                    "seed":  "node prisma/seed.js",
                    "test:smoke":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/smoke-test.js\u0027)\"",
                    "test:accounts":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/account-management-test.js\u0027)\"",
                    "test:guards":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/guard-test.js\u0027)\"",
                    "test:filters":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/filter-test.js\u0027)\"",
                    "test:monetization":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/monetization-test.js\u0027)\"",
                    "test:notifications":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/notification-test.js\u0027)\"",
                    "test:webhooks":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/webhook-test.js\u0027)\"",
                    "test:checkout-config":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/checkout-config-test.js\u0027)\"",
                    "test:geolocation":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/geolocation-test.js\u0027)\"",
                    "test:all":  "npm run seed \u0026\u0026 npm run test:smoke \u0026\u0026 npm run test:accounts \u0026\u0026 npm run test:guards \u0026\u0026 npm run test:filters \u0026\u0026 npm run test:geolocation \u0026\u0026 npm run test:monetization \u0026\u0026 npm run test:notifications \u0026\u0026 npm run test:webhooks \u0026\u0026 npm run test:checkout-config \u0026\u0026 npm run test:saved-searches \u0026\u0026 npm run test:payments \u0026\u0026 npm run test:disputes \u0026\u0026 npm run test:verification \u0026\u0026 npm run test:admin",
                    "test:saved-searches":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/saved-search-test.js\u0027)\"",
                    "test:payments":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/payment-test.js\u0027)\"",
                    "test:disputes":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/dispute-test.js\u0027)\"",
                    "test:admin":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/admin-test.js\u0027)\"",
                    "test:verification":  "node -e \"process.env.DISABLE_CSRF=\u0027true\u0027; require(\u0027./scripts/verification-test.js\u0027)\"",
                    "db:embedded":  "node scripts/embedded-postgres.js"
                },
    "dependencies":  {
                         "@aws-sdk/client-s3":  "^3.1006.0",
                         "@prisma/client":  "6.16.1",
                         "bcryptjs":  "^2.4.3",
                         "ejs":  "^3.1.10",
                         "express":  "^4.21.2",
                         "express-session":  "^1.18.1",
                         "multer":  "^2.0.2",
                         "node-cron":  "^4.2.1",
                         "nodemailer":  "^8.0.2",
                         "stripe":  "^20.4.1",
                         "uuid":  "^11.1.0"
                     },
    "devDependencies":  {
                            "embedded-postgres":  "^18.3.0-beta.16",
                            "prisma":  "6.16.1"
                        }
}
