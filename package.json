{
  "name": "fixmyhome-web",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-user FixMyHome web app",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --accept-data-loss",
    "seed": "node prisma/seed.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:guards": "node scripts/guard-test.js",
    "test:all": "npm run test:smoke && npm run test:guards"
  },
  "dependencies": {
    "@prisma/client": "6.16.1",
    "bcryptjs": "^2.4.3",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "node-cron": "^4.2.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "prisma": "6.16.1"
  }
}
