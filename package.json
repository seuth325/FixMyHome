{
  "name": "fixmyhome-web",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-user FixMyHome web app",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --accept-data-loss",
    "seed": "node prisma/seed.js",
    "test:smoke": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/smoke-test.js')\"",
    "test:accounts": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/account-management-test.js')\"",
    "test:guards": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/guard-test.js')\"",
    "test:filters": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/filter-test.js')\"",
    "test:monetization": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/monetization-test.js')\"",
    "test:notifications": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/notification-test.js')\"",
    "test:webhooks": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/webhook-test.js')\"",
    "test:checkout-config": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/checkout-config-test.js')\"",
    "test:geolocation": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/geolocation-test.js')\"",
    "test:all": "npm run seed && npm run test:smoke && npm run test:accounts && npm run test:guards && npm run test:filters && npm run test:geolocation && npm run test:monetization && npm run test:notifications && npm run test:webhooks && npm run test:checkout-config && npm run test:saved-searches && npm run test:payments && npm run test:disputes && npm run test:verification && npm run test:admin",
    "test:saved-searches": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/saved-search-test.js')\"",
    "test:payments": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/payment-test.js')\"",
    "test:disputes": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/dispute-test.js')\"",
    "test:admin": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/admin-test.js')\"",
    "test:verification": "node -e \"process.env.DISABLE_CSRF='true'; require('./scripts/verification-test.js')\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@prisma/client": "6.16.1",
    "bcryptjs": "^2.4.3",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "stripe": "^20.4.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "prisma": "6.16.1"
  }
}
